{
  "manifest_version": 3,
  "default_locale": "ja",
  "name": "__MSG_extensionName__",
  "version": "3.3.0",
  "description": "__MSG_extensionDescription__",
  "author": "Tetsuo Yokoyama",
  "browser_specific_settings": {
    "gecko": {
      "id": "ollama-reply@yokoyama-lab",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "messagesRead",
    "compose",
    "storage",
    "accountsRead"
  ],
  "host_permissions": [
    "http://localhost:11434/*",
    "http://localhost:11435/*",
    "http://127.0.0.1:11434/*",
    "http://127.0.0.1:11435/*"
  ],
  "message_display_action": {
    "default_title": "__MSG_generateReplyTitle__"
  },
  "action": {
    "default_title": "__MSG_monitorTitle__"
  },
  "commands": {
    "generate-reply": {
      "suggested_key": {
        "default": "Ctrl+Shift+R"
      },
      "description": "__MSG_generateReplyTitle__"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
